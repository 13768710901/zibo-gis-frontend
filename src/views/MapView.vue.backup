                      <div class="iso-top-sub">
                        <span>{{ formatDurationMinutes(item.durationSec) }}</span>
                        <span>·</span>
                        <span>{{ formatDistance(item.distanceMeters) }}</span>
                      </div>
                    </div>
                    <div>说明：等时圈叠加起点到最近设施的连线</div>
                  </div>
                </div>
