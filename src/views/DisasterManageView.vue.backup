<script setup>
import { ref, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import DisasterManagementPanel from '../components/DisasterManagementPanel.vue'
const router = useRouter()
const isAdmin = ref(false)
const loading = ref(true)

onMounted(() => {
  const userStr = localStorage.getItem('user')
  if (userStr) {
    const user = JSON.parse(userStr)
    // admin 和 reviewer 都有权限
    isAdmin.value = user.role === 'admin' || user.role === 'reviewer'
  }
  loading.value = false
})

const goBack = () => {
  router.push('/')
}
</script>

<template>
  <div class="disaster-manage-page">
    <!-- 加载中 -->
    <div v-if="loading" class="loading">
      加载中...
    </div>
    
    <!-- 无权限提示 -->
    <div v-else-if="!isAdmin" class="no-permission">
      <div class="icon">🚫</div>
      <h3>暂无权限</h3>
      <p>仅管理员可访问</p>
      <button class="back-btn" @click="goBack">返回首页</button>
    </div>
    
    <!-- 管理员显示管理面板 -->
    <DisasterManagementPanel v-else />
  </div>
</template>

